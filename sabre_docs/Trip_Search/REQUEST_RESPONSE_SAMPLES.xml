===================================================================================
RESPONSE STRUCTURE BREAKDOWN - WHAT EACH ELEMENT MEANS
===================================================================================

Trip_SearchRS ROOT ELEMENT
├─ Success = "Success"                              → Request was processed successfully
├─ ReservationsList
│  ├─ @NumberResults = "2"                          → 2 PNRs returned in this response
│  ├─ @TotalResults = "2"                           → 2 total matching PNRs
│  ├─ @NumberPages = "1"                            → Single page (no pagination needed)
│  └─ Reservations                                  → Container for all PNRs
│     └─ Reservation                                → Individual PNR record
│        ├─ @Locator = "FZVBDK"                     → PNR record locator (6-char code)
│        └─ stl119:GetReservationRS
│           └─ stl119:Reservation
│              ├─ @numberInParty = "2"              → Number of passengers
│              ├─ @numberOfInfants = "0"            → Number of infant passengers
│              ├─ BookingDetails
│              │  ├─ RecordLocator                  → PNR locator code
│              │  ├─ CreationTimestamp              → When PNR was created
│              │  ├─ UpdateTimestamp                → Last update time
│              │  ├─ PNRSequence                    → Version number
│              │  └─ EstimatedPurgeTimestamp        → When PNR will be deleted
│              ├─ POS
│              │  └─ Source
│              │     ├─ @PseudoCityCode             → Booking office code
│              │     ├─ @AirlineVendorID            → Airline code
│              │     └─ @ISOCountry                 → Country code
│              ├─ PassengerReservation
│              │  ├─ Passengers
│              │  │  └─ Passenger
│              │  │     ├─ @id                      → Internal passenger ID
│              │  │     ├─ @nameType = "S"          → "S" = Surname
│              │  │     ├─ @nameId                  → Name identifier
│              │  │     ├─ LastName                 → Family name
│              │  │     ├─ FirstName                → Given name + title
│              │  │     └─ Seats
│              │  │        └─ Seat
│              │  │           └─ @SeatLocation      → Seat number/location
│              │  ├─ Segments
│              │  │  └─ Segment
│              │  │     ├─ @id = "A"                → Segment identifier
│              │  │     ├─ @segmentType = "Air"     → Type of segment
│              │  │     └─ FlightDetails
│              │  │        ├─ Airline               → Airline code (ET)
│              │  │        ├─ FlightNumber          → Flight number (0001)
│              │  │        ├─ DepartureAirport      → Departure airport (JFK)
│              │  │        ├─ ArrivalAirport        → Arrival airport (AUH)
│              │  │        ├─ DepartureDateTime     → Departure date/time
│              │  │        ├─ ArrivalDateTime       → Arrival date/time
│              │  │        └─ ClassOfService        → Booking class (Y, J, F, etc.)
│              └─ CustomerContact
│                 └─ Phone (repeating)              → Each phone number
│                    ├─ PhoneNumber                 → The phone number digits
│                    └─ @PhoneType                  → H=Home, B=Business, M=Mobile, O=Other

===================================================================================
HOW TO PARSE THE RESPONSE - DATA EXTRACTION EXAMPLE
===================================================================================

TO EXTRACT PASSENGER DATA WITH PHONE NUMBERS, FOLLOW THIS LOGIC:

PSEUDO-CODE:
============

List<PassengerInfo> passengers = new List<PassengerInfo>();

foreach (Reservation in Trip_SearchRS.ReservationsList.Reservations)
{
    string pnrLocator = Reservation.Locator;
    
    var reservation = Reservation.stl119GetReservationRS.stl119Reservation;
    var phones = new List<string>();
    
    // Extract all phone numbers for this PNR
    if (reservation.CustomerContact != null)
    {
        foreach (Phone phone in reservation.CustomerContact.Phone)
        {
            phones.Add(new {
                Number = phone.PhoneNumber,
                Type = phone.PhoneType  // H, B, M, O
            });
        }
    }
    
    // Extract all passengers in this PNR
    if (reservation.PassengerReservation?.Passengers != null)
    {
        foreach (Passenger passenger in reservation.PassengerReservation.Passengers)
        {
            string lastName = passenger.LastName;
            string firstName = passenger.FirstName;  // May include title (e.g., "JOHN MR")
            string seatLocation = passenger.Seats?.Seat?[0]?.SeatLocation;
            
            // Create passenger record with associated phones
            PassengerInfo p = new PassengerInfo
            {
                PNRLocator = pnrLocator,
                LastName = lastName,
                FirstName = firstName,
                Seat = seatLocation,
                PhoneNumbers = phones,  // All phones for this PNR
                Airline = "ET",
                FlightNumber = "0001",
                DepartureDate = "2016-12-20",
                DepartureAirport = "JFK",
                ArrivalAirport = "AUH"
            };
            
            passengers.Add(p);
        }
    }
}

