	<xsd:simpleType name="YYYY-MM-DDDate">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[2][0-9][0-9][0-9]-(0[1-9]|1[0-2])-(0[1-9]|1[0-9]|2[0-9]|3[0-1])"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="YYYY-MM-DDDateWithMinLength0">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="([2][0-9][0-9][0-9]-(0[1-9]|1[0-2])-(0[1-9]|1[0-9]|2[0-9]|3[0-1])){0,1}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="YY-OR-YYYY-MM-DDDateWithMinLength0">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="(([2][0-9][0-9][0-9]|[0-9][0-9])-(0[1-9]|1[0-2])-(0[1-9]|1[0-9]|2[0-9]|3[0-1])){0,1}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="YYYY-MM-DDDateFrom1900">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="(((19[0-9][0-9])|([2][0-9][0-9][0-9]))-(0[1-9]|1[0-2])-(0[1-9]|1[0-9]|2[0-9]|3[0-1])){0,1}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="YY-OR-YYYY-MM-DDDateFrom1900">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="((((19[0-9][0-9])|([2][0-9][0-9][0-9]|[0-9][0-9])))-(0[1-9]|1[0-2])-(0[1-9]|1[0-9]|2[0-9]|3[0-1])){0,1}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="Numeric10">
		<xsd:restriction base="xsd:integer">
			<xsd:pattern value="[0-9]{10}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="Y_N_Indicator">
		<xsd:restriction base="xsd:string">
