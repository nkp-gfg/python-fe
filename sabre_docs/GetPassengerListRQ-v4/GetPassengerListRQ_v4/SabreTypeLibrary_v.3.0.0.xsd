					<xsd:documentation>type of aircraft of the flight like 777, S80, etc.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="change" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>indicator for aircraft change occurrence</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Status" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight status</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Indicator" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight indicator</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CityPair" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight city pair</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AircraftConfigNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight aircraft configuration</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AircraftRegistration" type="xsd:string" minOccurs="0"/>
			<xsd:element name="CheckinRuleNumber" type="xsd:string" minOccurs="0"/>
			<xsd:element name="SeatConfig" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight seat configuration</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Bag" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>no. of bags</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AutoOn" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>automatic on-board indiicator</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HeldSeat" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>no. of seats held</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FreeTextInfoList" type="FreeTextInfoList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>list of free text information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Text" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>text information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ApisInfoList" type="ApisInfoList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>APIS information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ApisInfoList.ACS">
		<xsd:sequence>
			<xsd:element name="ApisInfo" type="ApisInfo.ACS" minOccurs="0" maxOccurs="999"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ApisInfo.ACS">
		<xsd:sequence>
			<xsd:element name="City" type="xsd:string" minOccurs="0"/>
			<xsd:element name="Country" type="xsd:string" minOccurs="0"/>
			<xsd:element name="AQQ" type="xsd:string" minOccurs="0"/>
			<xsd:element name="ESTA" type="xsd:string" minOccurs="0"/>
			<xsd:element name="SF" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DCAR" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DCAD" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DOCO" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DOCV" type="xsd:string" minOccurs="0"/>
			<xsd:element name="PCTC" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DOCS" type="xsd:string" minOccurs="0"/>
			<xsd:element name="DocType" type="xsd:string" minOccurs="0"/>
			<xsd:element name="API" type="xsd:string" minOccurs="0"/>
			<xsd:element name="IAPP" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Korean APP or iAPP</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TIM" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>TIMATIC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TWAPP" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Taiwan APP</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BaggageRequestList.ACS">
		<xsd:sequence>
			<xsd:element name="BaggageRequest" type="BaggageRequest.ACS" maxOccurs="9"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BaggageRequest.ACS">
		<xsd:sequence>
			<xsd:element name="ACSBagTypeList" type="BagTypeList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>list of types of checked bags</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AEInfo" type="AEInfo.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>AE information for the bag request</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagInfo" type="BagInfo.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag identification</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="bagID" type="xsd:short" use="optional">
			<xsd:annotation>
				<xsd:documentation>Reference bag number for AE charges used only for internal ACS process</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="WeightAndSize.ACS">
		<xsd:sequence>
			<xsd:element name="WeightAndUnit" type="WeightAndUnit.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>weight and unit of bag to checkin</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LengthAndUnit" type="LengthAndUnit.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Length and unit of bag to checkin</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagTypeInfoList.ACS">
		<xsd:sequence>
			<xsd:element name="BagTypeInfo" type="BagTypeInfo.ACS" maxOccurs="25">
				<xsd:annotation>
					<xsd:documentation>Repeating element for details Bag Detail </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagTypeInfo.ACS">
		<xsd:sequence>
			<xsd:element name="ReasonList" type="ReasonList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Details for Reason code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="code" type="UpperCaseAlphaLength1" use="optional">
			<xsd:annotation>
				<xsd:documentation>bag type code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="description" type="UpperCaseAlphaNumericLength1to250" use="optional">
			<xsd:annotation>
				<xsd:documentation>bag type code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="HomePrintedBagTag.ACS">
		<xsd:sequence>
			<xsd:element name="ReasonList" type="ReasonList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reasons for restricting the generation Home Printed Bag Tag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="restriction" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>bag type code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="ReasonList.ACS">
		<xsd:sequence>
			<xsd:element name="Reason" type="Reason.ACS" maxOccurs="25"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Reason.ACS">
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Reason details</xsd:documentation>
				</xsd:annotation>
				<xsd:attribute name="code" type="NumericValue1to99" use="required">
					<xsd:annotation>
						<xsd:documentation>Reason Code</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="AEInfo.ACS">
		<xsd:choice>
			<xsd:element name="AEItemID" type="UpperCaseAlphaNumericLength1to6">
				<xsd:annotation>
					<xsd:documentation>unique id of the AE item</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GroupCode">
				<xsd:annotation>
					<xsd:documentation>Group and Sub codes for internal ACS use</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="UpperCaseAlphaNumericLength1to3">
							<xsd:attribute name="subCode" type="UpperCaseAlphaNumericLength1to3">
								<xsd:annotation>
									<xsd:documentation>sub-category code associated to AE group code</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:choice>
	</xsd:complexType>
	<xsd:complexType name="BagTypeList.ACS">
		<xsd:sequence>
			<xsd:element name="BagType" type="BagType.ACS" minOccurs="0" maxOccurs="6"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagType.ACS">
		<xsd:simpleContent>
			<xsd:extension base="UpperCaseAlphaLength1"/>
		</xsd:simpleContent>
	</xsd:complexType>
	<!--
		The seat map related XML structures are used in the following services:
			Seat map service response
			Passenger check-in service response
			Seat change service response
	-->
	<xsd:complexType name="FlightSeatMapInfo.ACS">
		<xsd:sequence>
			<xsd:element name="FlightInfo" type="FlightInfo.ACS">
				<xsd:annotation>
					<xsd:documentation>information about the flight, its legs and boarding by group.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightSeatMapDetail" type="FlightSeatMapDetail.ACS">
				<xsd:annotation>
					<xsd:documentation>list of details of the seat map for each cabin of the flight.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightInfo.ACS">
		<xsd:sequence>
			<xsd:element name="Airline" type="AirlineCode.IATA">
				<xsd:annotation>
					<xsd:documentation>airline/carrier code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Flight" type="FlightNumber.Base">
				<xsd:annotation>
					<xsd:documentation>flight number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Origin" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>flight departure airport or city code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Destination" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight arrival airport or city code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureDate" type="YYYY-MM-DDDate">
				<xsd:annotation>
					<xsd:documentation>flight departure date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureTime" type="Time_hhmma" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight departure time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureGate" type="GateName" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight departure gate number or id</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ArrivalTime" type="Time_hhmma" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight arrival time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Status" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>status of flight like open, close, boarding, etc.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AircraftType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight aircraft type, like 777, s80, etc.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="changeOfGauge">
								<xsd:annotation>
									<xsd:documentation>true if there's an aircraft change, otherwise, false, empty or omitted.</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="xsd:boolean">
										<xsd:pattern value="true"/>
										<xsd:pattern value="false"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AircraftConfigNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>aircraft configuration number </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightLegList" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence minOccurs="0">
						<xsd:element name="FlightLeg" minOccurs="0" maxOccurs="unbounded">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="SeqNumber" type="xsd:string"/>
									<xsd:element name="Origin" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation>flight leg departure airport or city code</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="GroupBoardingInfo" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>row details about boarding by group</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence minOccurs="0">
						<xsd:element name="BoardingMsg" type="xsd:string" minOccurs="0"/>
						<xsd:element name="BoardingRows" minOccurs="0" maxOccurs="unbounded">
							<xsd:complexType>
								<xsd:sequence minOccurs="0">
									<xsd:element name="GroupNumber" type="xsd:string" minOccurs="0"/>
									<xsd:element name="StartingRow" type="xsd:string" minOccurs="0"/>
									<xsd:element name="EndingRow" type="xsd:string" minOccurs="0"/>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightSeatMapDetail.ACS">
		<xsd:sequence>
			<xsd:element name="SeatMapDetail" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>detailed information of the columns and rows of seats. this includes row position of galleys, lavatories, etc.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="SeatMapDetail.ACS"/>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="SeatMapDetail.ACS">
		<xsd:sequence>
			<xsd:element name="SeatDetail" type="SeatDetail.ACS" maxOccurs="unbounded"/>
		</xsd:sequence>
		<xsd:attribute name="classOfService" type="xsd:string" use="required">
			<xsd:annotation>
				<xsd:documentation>cabin section of the flight</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="SeatDetail.ACS">
		<xsd:sequence>
			<xsd:element name="ColumnDetailList" type="ColumnDetailList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>location description of the columns like LAV, GAL, etc. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RowDetailList" type="RowDetailList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>list of seat row numbers and their column letters</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ColumnDetailList.ACS">
		<xsd:sequence>
			<xsd:element name="ColumnDetail" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:choice>
						<xsd:element name="Column" maxOccurs="unbounded">
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:string">
										<xsd:attribute name="characteristic" type="xsd:string">
											<xsd:annotation>
												<xsd:documentation>seat column description like Aisle</xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="Description" type="xsd:string" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation>free text description of columns for GAL, LAV, BHD, etc.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="PhysicalAircraftType" type="xsd:string" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>free text description of columns for GAL, LAV, BHD, etc.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:choice>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="RowDetailList.ACS">
		<xsd:sequence>
			<xsd:element name="Row" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="RowCharacteristic" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation>decrription of the seat such as exit, wing.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="Column" maxOccurs="unbounded">
							<xsd:complexType>
								<xsd:sequence minOccurs="0">
									<xsd:element name="ColumnCharacteristic" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>decription of the seat example
												J Upper deck seat
												L Lounge seat
												U Undesirable seat 
												blank Non-existent/Crew rest and additional cabin jumpseat	
												@ (Change Key) Smoking rows on a partially smoking flight
												X Exit row indicator
												W Wing indicator
												P Paid seat
												L Main Cabin Extra (AA)
												Y Rear Facing seat
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="SeatCharacteristics" type="UpperCaseAlphaNumericLength3" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>3 character Seat Characteristics keyword</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="PADISCode" type="UpperCaseAlphaNumericLength1to2" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>1 to 2 char PADIS code, for example:
												9825 Seat characteristic, coded
												1 Restricted seat - General
												2 Leg rest available
												3 Individual video screen - Choice of movies
												4 Not a window seat
												5 Not an aisle seat
												6 Near galley seat
												7 Near toilet seat
												8 No seat at this location
												9 Center seat (not window, not aisle)
												10 Seat designated for RBD "A"
												11 Seat designated for RBD "B"
												12 Seat designated for RBD "C"
												13 Seat designated for RBD "D"
												14 Seat designated for RBD "F"
												15 Seat designated for RBD "H"
												16 Seat designated for RBD "J"
												17 Seat designated for RBD "K"
												18 Seat designated for RBD "L"
												19 Seat designated for RBD "M"
												20 Seat designated for RBD "P"
												21 Seat designated for RBD "Q"
												22 Seat designated for RBD "R"
												23 Seat designated for RBD "S"
												24 Seat designated for RBD "T"
												25 Seat designated for RBD "V"
												26 Seat designated for RBD "W"
												27 Seat designated for RBD "Y"
												28 Not fitted
												A Aisle seat
												AA All available aisle seats
												AB Seat adjacent to bar
												AC Seat adjacent to - closet
												AG Seat adjacent to galley
												AJ Adjacent aisle seats
												9825 Seat characteristic, coded (continued)
												AL Seat adjacent to lavatory
												AM Individual movie screen - No choice of movie selection
												AR No seat - airphone
												AS Individual airphone
												AT Seat adjacent to table
												AU Seat adjacent to stairs to upper deck
												AV Only available seats
												AW All available window seats
												B Seat with bassinet facility
												BA No seat - bar
												BK Blocked Seat for preferred passenger in adjacent seat
												C Crew seat
												CC Center section seat(s)
												CH Chargeable seat
												CL No seat - closet
												CS Conditional seat-contact airline
												D No seat - exit door
												DE Deportee
												E Exit and emergency exit
												EA Not on exit seat
												EC Electronic connection for lap top or FAX machine
												+ EK Economy comfort seat
												EX No seat - emergency Exit
												F Added seat
												FC Front of cabin class/compartment
												G Seat at forward end of cabin
												GF General facility
												GN No seat - galley
												GR Group seat - offered to travellers belonging to a group
												H Seat with facilities for handicapped/incapacitated passenger
												I Seat suitable for adult with an infant
												IA Inside aisle seats
												IE Seat not suitable for child
												J Rear facing seat
												K Bulkhead seat
												KA Bulkhead seat with movie screen
												KN Bulkhead, no seat
												L Leg space seat
												LA No seat - lavatory
												LG No seat - luggage storage
												LH Restricted seat - offered on long-haul segments
												LS Left side of aircraft
												M Seat without a movie view
												MA Medically OK to travel
												N No smoking seat
												O Preferential seat
												OW Overwing seat(s)
												PC Pet cabin
												Q Seat in a quiet zone
												RS Right side of aircraft
												S Smoking seat
												SO No seat - storage space
												ST No seat - stairs to upper deck
												T Rear/Tail section of aircraft
												TA No seat - table
												U Seat suitable for unaccompanied minors
												UP Upper deck
												V Seat to be left vacant or offered last
												W Window seat
												WA Window and aisle together
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="FacilityList" minOccurs="0">
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="FacilityInfo" maxOccurs="10">
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="FacilityCode" type="UpperCaseAlphaNumericLength1to3">
																<xsd:annotation>
																	<xsd:documentation>1 to 3 character code for example:
																		DOR door 
																		GAL galley
																		LAV lavatory
																		PAL preferred_access_lavat,
																		SCR movie_screen
																		SHW shower                  
																		PRY prayer room
																		STR staircase                  
																		LNG lounge
																		BAR bar
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FacilityDirection" type="UpperCaseAlphaNumericLength1" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>1 character direction code for example:
																		L left
																		R right
																		O overlay
																		F front
																		B back
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PADISCode" type="UpperCaseAlphaNumericLength1to2" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>1 to 2 char PADIS code for Facility</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
								</xsd:sequence>
								<xsd:attribute name="letter" type="xsd:string" use="required">
									<xsd:annotation>
										<xsd:documentation>seat column letter</xsd:documentation>
									</xsd:annotation>
								</xsd:attribute>
								<xsd:attribute name="blockCode" type="xsd:string">
									<xsd:annotation>
										<xsd:documentation>block description of seat like Z=airport block, Q=premium travel block, *=available, dot=occuppied, etc.</xsd:documentation>
									</xsd:annotation>
								</xsd:attribute>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
					<xsd:attribute name="number" type="xsd:int" use="required">
						<xsd:annotation>
							<xsd:documentation>seat row number</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!--
