	<xsd:simpleType name="_flightNumberLiterals">
		<xsd:annotation>
			<xsd:documentation>This private type enumerates flight number literals used for ground links and open segments in an itinerary.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="OPEN">
				<xsd:annotation>
					<xsd:documentation>Used in lieu of a flight number when a specific flight number is unknown but service is present.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ARNK">
				<xsd:annotation>
					<xsd:documentation>Used in lieu of a flight number when surface transportation is used when there is a break in the continuity of the flight itinerary.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
