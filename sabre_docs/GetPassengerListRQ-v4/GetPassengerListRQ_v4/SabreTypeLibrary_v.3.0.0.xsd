					<xsd:documentation>Travel Doc Data  (ADT - Adult Boarding Pass, INF - Infant Boarding Pass, LC - Lounge Card, MV - Meal Voucher, PV - Priority Verify) from TPF</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
