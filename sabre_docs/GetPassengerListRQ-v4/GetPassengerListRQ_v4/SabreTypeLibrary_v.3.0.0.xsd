				<xsd:annotation>
					<xsd:documentation>A trip with only one connection.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DoubleConnection">
				<xsd:annotation>
					<xsd:documentation>A trip with only two connections.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OneStopOnly">
				<xsd:annotation>
					<xsd:documentation>Indicates that the flight makes only one stop.</xsd:documentation>
				</xsd:annotation>
