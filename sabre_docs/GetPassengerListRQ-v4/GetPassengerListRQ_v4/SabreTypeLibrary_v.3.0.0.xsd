				<xsd:annotation>
					<xsd:documentation>Hard or soft match internal filtering  (Pricing schema tag OOS-PS1)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GroupCode" type="UpperCaseAlphaNumericLength1to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Type of AE examples BG, PT, SA  (Pricing schema tag OSG-SF0)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SubCode" type="UpperCaseAlphaNumericLength1to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Code relates to specific item example 0AA means Prepaid Baggage  (Pricing schema tag OSC-SHK)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Descriptions" type="Descriptions.ACS" minOccurs="0"/>
			<xsd:element name="SubGroup" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Category/Sub group description like Sporting Equipment  (Pricing schema tag OSC-ASD)</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="code" type="UpperCaseAlphaNumericLength1to3">
								<xsd:annotation>
									<xsd:documentation>Sub group code  (Pricing schema tag OSC-OSG)</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AncillaryServiceType" type="UpperCaseAlphaLength1" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Ancillary Service Type (Pricing schema tag ITT-AST)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RficCode" type="UpperCaseAlphaLength1" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>RFIC Code - Reason for Issuance (Pricing schema tag ITT-N01)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BaggageWeightAndSize" type="AncillaryBagWeightAndSize.ACS" minOccurs="0"/>
			<xsd:element name="BaggageData" type="BaggageData.ACS" minOccurs="0"/>
			<xsd:element name="ActionCode" type="UpperCaseAlphaNumericLength1to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Status code (Pricing schema tag OCG-ST0)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Vendor" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Vendor Code (Pricing schema tag ITT-SFV)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FeeIndicator" type="UpperCaseAlphaNumericLength1" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Fee Application Indicator (Pricing schema tag FAT-N41)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ChargeIndicator" type="UpperCaseAlphaLength1" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>No Charge/Not Avaiable Indicator (Pricing schema tag FAT-N43)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxesIncluded" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Tax Exempt Indicator (Pricing schema tag OOS-PY0)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EMDType" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>EMD Type (Pricing schema tag OSC-N02)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Refund" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Refund/Reissue (Pricing schema tag FAT-N45)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BaggageAllowance" type="BaggageAllowance.ACS" minOccurs="0"/>
			<xsd:element name="PriceDetails" type="PriceDetails.ACS" minOccurs="0"/>
			<xsd:element name="AncillaryFreeTextInfoList" type="FreeTextInfoList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>list of free text Bag detail description information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="PassengerID" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>Passenger Unique ID is used for selected fees - Internal use only</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="BagID" type="xsd:short" use="optional">
			<xsd:annotation>
				<xsd:documentation>Reference bag number for AE charges internal use only</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="ItemID" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>unique id for each AE - Internal use only</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="BaggageAllowance.ACS">
