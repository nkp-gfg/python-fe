			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<!--
		The SeatCharacteristic structure is used in the check-in request and seat change services. 
	-->
	<xsd:simpleType name="SeatCharacteristic">
		<xsd:annotation>
			<xsd:documentation>Seating Area Codes: A - Aisle; W - Window - assumed if other zones not requested; L - Left side of the compartment; R - Right side of the compartment; B - Bulkhead; F - Front of cabin; T - Tail (rear of aircraft); X - Aisle's opposite, valid for two passengers only; E - Exit row; S - Smoking; N - Non-smoking (default is non-smoking if smoking is not specified</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="StringLength1to16">
			<xsd:enumeration value="Aisle"/>
			<xsd:enumeration value="Window"/>
			<xsd:enumeration value="Left Side"/>
			<xsd:enumeration value="Right Side"/>
			<xsd:enumeration value="Bulkhead"/>
			<xsd:enumeration value="Front"/>
			<xsd:enumeration value="Tail"/>
			<xsd:enumeration value="X-Aisle Opposite"/>
			<xsd:enumeration value="Exit"/>
			<xsd:enumeration value="Smoking"/>
			<xsd:enumeration value="Non-smoking"/>
		</xsd:restriction>
	</xsd:simpleType>
