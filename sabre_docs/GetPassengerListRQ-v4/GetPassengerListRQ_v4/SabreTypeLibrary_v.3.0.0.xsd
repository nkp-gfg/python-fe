			<xsd:element name="BaggageRoute" type="BaggageRoute.ACS" minOccurs="0" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BaggageRoute.ACS">
		<xsd:sequence>
			<xsd:element name="SegmentID" type="xsd:short">
				<xsd:annotation>
					<xsd:documentation>segment sequence no. in the list</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Airline" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>airline code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Flight" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>flight number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BookingClass" type="StringLength1to2" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>booking class</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OperatingAirline" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>operating airline code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OperatingFlight" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>operating flight number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Origin" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>flight departure city code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Destination" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>flight arrival city code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureDate" type="YYYY-MM-DDDate">
				<xsd:annotation>
					<xsd:documentation>flight departure date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureTime" type="Time_hhmma" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight departure time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ArrivalDate" type="YYYY-MM-DDDate" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight arrival date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ArrivalTime" type="Time_hhmma" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>flight arrival time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SegmentStatus" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>confirmation status of the segment</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PassengerID" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>character string uniquely identifying the passenger</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagEmbargo" type="xsd:short" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag embargo flag for this segment</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PetRestriction" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>pet restriction indicator for this segment</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FreeText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>free text information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BaggageRestrictionLimit" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Number of bags allowed to travel with the passenger. Any quantity over the maximum allowance will be issued as voluntary separation</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LateCheckin" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicate when a bag will not be check-in to flight due to late check-in time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ShortCheckinReason" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicate the short check reason why the baggage will not reach a destination. Possible values: No interline baggage agreement, Unauthorized baggage route</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HomePrintedBagTag" type="HomePrintedBagTag.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reason for restricting the Home Printed BagTag for a passenger based on the Departure city ,Routing or Airline policy</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagTagInfoList.ACS">
		<xsd:annotation>
			<xsd:documentation>collection of bagtag info</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BagTagInfo" type="BagInfo.ACS" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>bag tag information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalWeightAndUnit" type="WeightAndUnit.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>total weight for all bags</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- hpbt btxml -->
	<xsd:complexType name="ParseBagTagNumber.ACS">
		<xsd:annotation>
			<xsd:documentation>Parsing the ten digit bag Tag number</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BagTagSixDigitNumber" type="xsd:string" minOccurs="0" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>6 digit bag tag number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IndexNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag Tag index number based upon Origin , destination  or Interline or Manual Bag Tag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AirlineCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Three digit IAIA Airline numeric code </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BTXMLPassengerInfo.ACS">
		<xsd:sequence>
			<xsd:element name="LastName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger's official last name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FirstName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger's official first name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BTXMLFlightInfo.ACS">
		<xsd:sequence>
			<xsd:element name="AirlineName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Airline name in which the passenger is travelling</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OperatingAirlineCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>IATA Airline code.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Service number for the flight</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureDate" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Schedule Departure Date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureTime" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Schedule Departure Time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureDateEstimated" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Estimated Departure Date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureTimeEstimated" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Estimated Departure Time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BTXMLAgentSignInfo.ACS">
		<xsd:complexContent>
			<xsd:extension base="AgentInfo.ACS">
				<xsd:sequence>
					<xsd:element name="LNIATA" type="xsd:string" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Line Number Interchange Address Terminal Address</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="BagTagPrintData.ACS">
		<xsd:sequence>
			<xsd:element name="PassengerNameInfo" type="BTXMLPassengerInfo.ACS" minOccurs="1" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>Passenger complete name information to whom, the bags belongs</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReservationInfo" type="ReservationInfo.ACS">
				<xsd:annotation>
					<xsd:documentation>Reservation details of the passenger who checks the bag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AgentInfo" type="BTXMLAgentSignInfo.ACS">
				<xsd:annotation>
					<xsd:documentation>This is Issuing Agent information, who checks in the bags, on behalf of the passenger, and this information also represents the point of sale</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightInfo" type="BTXMLFlightInfo.ACS">
				<xsd:annotation>
					<xsd:documentation>Operating airline, and flight detail information on which , the passenger is travelling and checks in the bag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagInfoList" type="BTXMLBagInfoList.ACS" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>List of Bag Specific information that would be printed on each bag tag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ReservationInfo.ACS">
		<xsd:sequence>
			<xsd:element name="CabinClass" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Aircraft Cabin class on which the passenger is travelling</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BookingClass" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reservation Booking designator or selling class as booked in the passenger's itinerary</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PNRLocator" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger name record locator</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="nameAssociationID" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>PNR name association ID</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="nameRefNumber" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>PNR name Reference Number</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BTXMLBagInfoList.ACS">
		<xsd:sequence>
			<xsd:element name="BagInfo" type="BTXMLBagInfo.ACS" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>Bag specific information printed on the tag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="totalBagCount" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>number of bags that the passenger has checked in</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="totalBagWeight" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>Total weight of the bags checked in by the passenger</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="totalBagWeightUnit" type="xsd:string" use="optional">
			<xsd:annotation>
				<xsd:documentation>unit weight of measure, of the bags</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="BTXMLBagTagInfo.ACS">
		<xsd:sequence>
			<xsd:element name="BagTagNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>10 digit Bag tag number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IssuedAirlineCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag Tag Issuing Airline code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IssueDate" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Date of bag tag issue</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IssueTime" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Time of bag tag issue</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ParseBagTagNumber" type="ParseBagTagNumber.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>10 digit bag tag number and its details</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagTextsList.ACS">
		<xsd:sequence>
			<xsd:element name="BagText" type="BagText.ACS" minOccurs="1" maxOccurs="25">
				<xsd:annotation>
					<xsd:documentation>Printable text on bag tags based on carrier preferences or regulator guidelines</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagText.ACS">
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Reason details</xsd:documentation>
				</xsd:annotation>
				<xsd:attribute name="textType" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>Represents the type of text that will be presented on the bag tag such as Selectee, Quick Transfer Bags</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="BTXMLBagInfo.ACS">
		<xsd:sequence>
			<xsd:element name="IndividualWeightAndUnit" type="WeightAndUnit.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>individual weight and its unit of measure</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagTagInfo" type="BTXMLBagTagInfo.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>10 or 6 digit Bag tag number and its issuance details</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagTexts" type="BagTextsList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Printable Description Text on Bag Tag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpecialServiceTypeList" type="SpecialServiceTypeList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Special printable text on bag tag based on airline offered services</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RelativeBagSequenceNo" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Baggage tag sequence number relative to the total bags checked in that time</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagTypeInfoList" type="BagTypeInfoList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag tag type text, optionally with a  reason for issuance</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagRouteInfoList" type="BagRouteInfoList.ACS" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>Destination and connecting flight information thru transfer segments for the bag route</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="SpecialServiceTypeList.ACS">
		<xsd:sequence>
			<xsd:element name="SpecialServiceType" type="SpecialServiceType.ACS" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>list of types of checked bags</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="SpecialServiceType.ACS">
		<xsd:simpleContent>
			<xsd:extension base="UpperCaseAlphaWithBlank">
				<xsd:annotation>
					<xsd:documentation>Special Bag Service Types </xsd:documentation>
				</xsd:annotation>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="BagRouteInfoList.ACS">
		<xsd:sequence>
			<xsd:element name="BagRouteInfo" type="BagRouteInfo.ACS" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>Destination and connecting flight information thru transfer segments for the bag route</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="WetLeaseAirlineInfo.ACS">
		<xsd:sequence>
			<xsd:element name="WetleaseOperatedBy" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Wetlease operated by text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WetleaseAirlineName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Wetlease Operating Airline Name </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WetleaseFlightConfig" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Wetlease Aircraft configuration</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="CommuterAirlineInfo.ACS">
		<xsd:sequence>
			<xsd:element name="CommuterAirlineCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Commuter Airline code </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CommuterAirlineName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Commuter Airline name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BTXMLOperatingTypeAirlineInfo.ACS">
		<xsd:sequence>
			<xsd:element name="WetLeaseAirlineInfo" type="WetLeaseAirlineInfo.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Wetlease Operating Airline information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CommuterAirlineInfo" type="CommuterAirlineInfo.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Commuter Airline Information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagRouteCarrierInfo.ACS">
		<xsd:simpleContent>
			<xsd:extension base="UpperCaseAlphaWithBlank">
				<xsd:annotation>
					<xsd:documentation>Bag type descrption</xsd:documentation>
				</xsd:annotation>
				<xsd:attribute name="name" type="UpperCaseAlphaLength1to30" use="required">
					<xsd:annotation>
						<xsd:documentation>bag type code</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="code" type="UpperCaseAlphaLength1to3" use="required">
					<xsd:annotation>
						<xsd:documentation>bag type code</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="BTXMLDestinationInfo.ACS">
		<xsd:sequence>
			<xsd:element name="CityCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>IATA City code of the transfer segment or destination</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CityName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>IATA city name  of the transfer segment or destination</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CountryCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>ISO country code of the transfer segment or destination</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagRouteInfo.ACS">
		<xsd:sequence>
			<xsd:element name="FlightInfo" type="BTXMLFlightInfo.ACS" minOccurs="0" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>Bag tag route segment flight information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CheckinSequenceNo" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger check in sequence Number relative to other passengeres checked-in on the flight</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DestinationInfo" type="BTXMLDestinationInfo.ACS" minOccurs="0" maxOccurs="1">
				<xsd:annotation>
					<xsd:documentation>Baggage Destination City information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OperatingTypeAirlineInfo" type="BTXMLOperatingTypeAirlineInfo.ACS" minOccurs="0" maxOccurs="9">
				<xsd:annotation>
					<xsd:documentation>Operating ailine aircraft's Wetlease or Commuter detail information</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AirportZoneGroup" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicator for STAR ALLIANCE Connection</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- end HPBT BTXML-->
	<xsd:complexType name="BagInfo.ACS">
		<xsd:annotation>
			<xsd:documentation>collection of bagtag info</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BagTagNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag tag number not applicable for request</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WeightAndSize" type="WeightAndSize.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag identification</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagStatus" type="AirExtraStatus.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>state of bag not applicable for request</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BagTagInfo.ACS">
		<xsd:annotation>
			<xsd:documentation>Bag Tag details with additional information</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BagTagNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag tag number not applicable for request</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagTypeInfoList" type="BagTypeInfoList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag tag type text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WeightAndSize" type="WeightAndSize.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>bag weight details</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Airline" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>airline code for checked bag</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagOrigin" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag Origin</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BagFinalDestination" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Bag Final Destination</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AEItemID" type="xsd:string" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>unique id for linked AE</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="AirExtraStatus.ACS">
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="aeStatus" type="AEStatus.ACS"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:simpleType name="AEStatus.ACS">
		<xsd:annotation>
			<xsd:documentation>Air Extra bag status</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="Paid"/>
