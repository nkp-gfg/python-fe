						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AircraftRegistration" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AircraftRegistration">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AircraftConfiguration" type="AircraftVersionandClassConfiguration" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ErrorMessage">
		<xsd:annotation>
			<xsd:documentation>Free text and code provided by the application or system that detected the error. Contants may be anything the system detecting the error chooses to convey. Used by service consumers.  Codes and/or messages should be agreed upon by service users. Do not use for structured data, use parameters instead.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="Text.Long">
				<xsd:attribute name="code" type="xsd:integer"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="ExchangeDocument.Misc">
		<xsd:sequence>
			<xsd:element name="DocumentNumber" type="DocumentNumber"/>
			<xsd:element name="IssueDate" type="xsd:date"/>
			<xsd:element name="IssuePlace" type="AlphaNumericStringLength1to5"/>
			<xsd:element name="OrigFop" type="StringLength1to18"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Fee.Grouped">
		<xsd:sequence>
			<xsd:element name="FeeDetails" type="FeeDetails.Misc"/>
			<xsd:element name="OptionalService" type="OptionalService" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Specific information about optional service (OC) as published in ATPCO or Merchandiziing</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Valuation" type="Valuation" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Additional charges associated to a high value or excess valuation of an item</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Tax" type="Tax.Misc" minOccurs="0" maxOccurs="99"/>
			<xsd:element name="AirportTax" type="AirportTax" minOccurs="0" maxOccurs="32"/>
			<xsd:element name="IssuedDocumentNumber" type="DocumentNumber" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Fee.Linked">
		<xsd:sequence>
			<xsd:element name="FeeDetails" type="FeeDetails.Misc"/>
			<xsd:element name="OptionalService" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Specific information about optional service (OC) as published in ATPCO or Merchandiziing</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="OptionalService"/>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Valuation" type="Valuation" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Additional charges associated to a high value or excess valuation of an item</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AssociatedFlight" type="Flight.Misc" minOccurs="0" maxOccurs="4">
				<xsd:annotation>
					<xsd:documentation>Fee can be associated to a flight coupon.  When applicable, connecting or downline flights are included in this element.  Use AssociatedFlight if miscellaneous items have PRAS codes that required flight coupons and are originally processed thru the following MISC options:

MISC2/4 - CHANGE FEE
MISC2/5 - OPTIONAL FEE
EMD-A (Future)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Tax" type="Tax.Misc" minOccurs="0" maxOccurs="99"/>
			<xsd:element name="AirportTax" type="AirportTax" minOccurs="0" maxOccurs="32"/>
			<xsd:element name="AssociatedTicketNumber" type="DocumentNumber" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Fee can be associated to a ticket number</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IssuedDocumentNumber" type="DocumentNumber" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FeeDetails.Misc">
		<xsd:sequence>
			<xsd:element name="Base" type="Amount" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The base fee amount associated to the item or service which does not include taxes.   Mapped to: SR05_C1_BAMT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Equiv" type="Amount" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The equivalent or converted fee amount associated to the item or service which does not include taxes.   Mapped to: SR05_C1_BAMT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalTax" type="Amount" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total fee taxes associated to the item or service purchased.   Mapped to: SR05_C1_TAMT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Total" type="Amount" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total fee amount associated to the service including taxes.   Mapped to: SR05_C1_FAMT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EffectiveDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date the fee and amounts will be effective or can be used for purchase.  Mapped to:  SR05_C1_EFFD</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="code" type="StringLength1to3" use="required">
			<xsd:annotation>
				<xsd:documentation>PRAS code associated to the  service or item.  Mapped to: SR05_C1_PRAS</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="description" type="StringLength1to21">
			<xsd:annotation>
				<xsd:documentation>Description of the purchased item or service.  Mapped to: SR05_C1_DESC</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="quantity" type="xsd:int">
			<xsd:annotation>
				<xsd:documentation>The number of items purchased per PRAS code.  Mapped to: SR05_C1_IQTY</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="FeeItem.Misc">
		<xsd:sequence>
			<xsd:element name="FeeDetails" type="FeeDetails.Misc"/>
			<xsd:element name="Tax" type="Tax.Misc" minOccurs="0" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FeeList.Misc">
		<xsd:sequence>
			<xsd:element name="Fee" type="FeeItem.Misc" maxOccurs="999"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Fees.Grouped">
		<xsd:sequence>
			<xsd:element name="Customer" type="Customer.Misc"/>
			<xsd:element name="TicketNumber" type="DocumentNumber" minOccurs="0" maxOccurs="6">
				<xsd:annotation>
					<xsd:documentation>One or more fees are related to one or more ticket numbers. Use TicketNumber if miscellaneous items have PRAS codes that are originally processed thru the following MISC options and required ticket numbers:

MISC2/1 - SALES ITEMS
MISC2/2 - SERVICES
MISC2/3 - UNPAID TAXES
MISC3 - EXCESS BAGGAGE TICKET</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Flight" type="Flight.Misc" minOccurs="0" maxOccurs="4">
				<xsd:annotation>
					<xsd:documentation>One or more fees are related to one or more flight coupons.  Use Flight if miscellaneous items have PRAS codes that are originally processed thru the following MISC options and required flight coupons:

MISC2/1 - SALES ITEMS
MISC2/2 - SERVICES
MISC2/3 - UNPAID TAXES
MISC3 - EXCESS BAGGAGE TICKET</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Fee" type="Fee.Grouped" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Fees.Linked">
		<xsd:sequence>
			<xsd:element name="Customer" type="Customer.Misc"/>
			<xsd:element name="Fee" type="Fee.Linked" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FeesType">
		<xsd:choice>
			<xsd:group ref="Fees.Association" minOccurs="0"/>
		</xsd:choice>
	</xsd:complexType>
	<xsd:complexType name="Flight.Identifier">
		<xsd:simpleContent>
			<xsd:extension base="FlightNumber">
				<xsd:attribute name="carrier" type="AirlineCode" use="required">
					<xsd:annotation>
						<xsd:documentation>By default, the carrier is assumed from the transaction context</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="date" type="Date" use="required">
					<xsd:annotation>
						<xsd:documentation>By default, the date is assumed to be today or unspecified identifing a group of flights with the same number.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Flight.Identifier.SSI">
		<xsd:simpleContent>
			<xsd:extension base="FlightNumber.Base">
				<xsd:attribute name="carrier" type="AirlineCode" use="required">
					<xsd:annotation>
						<xsd:documentation>By default, the carrier is assumed from the transaction context</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="date" type="Date" use="required">
					<xsd:annotation>
						<xsd:documentation>By default, the date is assumed to be today or unspecified identifing a group of flights with the same number.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Flight.Identifier.withSuffix">
		<xsd:sequence>
			<xsd:element name="FlightNumber">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="FlightNumber.Base">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Suffix" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="FlightNumber.OperationalSuffix">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Carrier">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirlineCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Date">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="Date">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Flight.Misc">
		<xsd:sequence>
			<xsd:element name="CarrierCode" type="AirlineCode">
				<xsd:annotation>
					<xsd:documentation>The carrier code of the flight associated to the service.  Mapped to:  SR05_42_CXRC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightNumber" type="FlightNumber">
				<xsd:annotation>
					<xsd:documentation>The flight number associated to the service.   Mapped to: SR05_42_FLTN</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ClassOfService" type="CabinType.3Chars">
				<xsd:annotation>
					<xsd:documentation>The flight class of service associated to the ancillary service.  Mapped to: SR05_42_CLSV</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureCity" type="CityCode">
				<xsd:annotation>
					<xsd:documentation>The origin or depature city code of the flight associated to the service.   Mapped to: SR05_42_DCTY</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ArrivalCity" type="CityCode">
				<xsd:annotation>
					<xsd:documentation>The destination or arrival city of the flight associated to the service.   Mapped to: SR05_42_ACTY</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepartureDate" type="xsd:date">
				<xsd:annotation>
					<xsd:documentation>The departure date of the flight associated to the service.  Mapped to: SR05_42_CDTE</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StopOver" type="AlphaNumericStringLength1" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A code that applies to whether the flight is a stop over or not (X, O).   Mapped to: SR05_42_STOV</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightAirports">
		<xsd:annotation>
			<xsd:documentation>Scheduled departure airport should be the same as the airport contained in Flight Leg identifier.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ScheduledDeparture">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirportCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="LatestDeparture" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirportCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="DepartureINDOIndicator">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="INDO">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ScheduledArrival">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirportCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="LatestArrival" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirportCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ArrivalINDOIndicator">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="INDO">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightLeg.Identifier">
		<xsd:sequence>
			<xsd:element name="Origin" type="AirportCode"/>
			<xsd:element name="DepartureDate" type="OperationTime">
				<xsd:annotation>
					<xsd:documentation>Published Departure Time should be the same as contained in flight times / Published / Departure</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightLeg.OPS">
		<xsd:sequence>
			<xsd:element name="FlightId" type="Flight.Identifier.withSuffix"/>
			<xsd:element name="ReplacementFlightId" type="Flight.Identifier.withSuffix" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Existance of this ID indicates that the flight identifier has changed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightLegId" type="FlightLeg.Identifier"/>
			<xsd:element name="ReplacementFlightLegId" type="FlightLeg.Identifier" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Existance of this ID indicates that the flight leg identifier has changed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FlightLegReferenceNumber" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="StringLength0to64">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ServiceType">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="ServiceType">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="VersionNumber">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:int">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Equipment" type="EquipmentInformation"/>
			<xsd:element name="Airports" type="FlightAirports"/>
			<xsd:element name="Time" type="FlightTimes"/>
			<xsd:element name="Delay" type="DelayInformation" minOccurs="0"/>
			<xsd:element name="Status">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="LegStatus">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="SpecialStatus" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="SpecialLegStatus">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Gate" type="GateInformation" minOccurs="0"/>
			<xsd:element name="ChangeReasons" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="ChangeReasons">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="CancelReasonCode" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="ChangeReason.SSIM">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Remarks" type="Remarks" minOccurs="0"/>
			<xsd:element name="OnwardFlight" type="Flight.Identifier.withSuffix" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Changes will be indicated in the elements contained in the identifier.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PassengerCounts" type="PassengerCounts" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightTimes">
		<xsd:annotation>
			<xsd:documentation>Published Departure Time should be the same as contained in flight leg identifier.
1.     OriginalTimes, PublishedTimes and ScheduleTimes are the same either when a flight is created in Movement Manager (MM) manually or through parsing SSIM.
2.     PublishedTimes – Are changes to times resulted because of an ASM from Airflite or Schedule Manager product. A manual Retime operation in MM can also change the published time.
3.     ScheduleTimes – Usually the same as Published or Original times except for the cases explained in item 1 and 2. MM user can reschedule a flight through the application to change the Schedule times.

</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Original" type="FlightTimes.DepartureArrival"/>
			<xsd:element name="Published" type="FlightTimes.Scheduled"/>
			<xsd:element name="PreviousPublished" type="FlightTimes.Scheduled" minOccurs="0"/>
			<xsd:element name="Scheduled" type="FlightTimes.Scheduled" minOccurs="0"/>
			<xsd:element name="Estimated" type="FlightTimes.Operational" minOccurs="0"/>
			<xsd:element name="Actual" type="FlightTimes.Operational" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightTimes.DepartureArrival">
		<xsd:sequence>
			<xsd:element name="Departure">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Arrival">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightTimes.Operational">
		<xsd:sequence>
			<xsd:element name="BlockOff" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TakeOff" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TouchDown" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="BlockOn" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FlightTimes.Scheduled">
		<xsd:sequence>
			<xsd:element name="Departure">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="PassengerDeparture" nillable="true" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Arrival">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="PassengerArrival" nillable="true" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="OperationTime">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="FormOfIdentification.Misc">
		<xsd:sequence>
			<xsd:element name="Number" type="AlphaNumericStringLength1to25">
				<xsd:annotation>
					<xsd:documentation>A number that would identify the person who purchases the service.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="code" use="required">
			<xsd:annotation>
				<xsd:documentation>Unique code that identifies the typ of id the person has used for purchasing the service or item</xsd:documentation>
			</xsd:annotation>
			<xsd:simpleType>
				<xsd:restriction base="PrimaryIdCodeList"/>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="secondaryId">
			<xsd:annotation>
				<xsd:documentation>Unique code associiated to the secondary ID</xsd:documentation>
			</xsd:annotation>
			<xsd:simpleType>
				<xsd:restriction base="SecondaryIdCodeList"/>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="state" type="AlphaLength2"/>
	</xsd:complexType>
	<xsd:complexType name="FormOfPaymentChoice.Misc">
		<xsd:choice>
			<xsd:element name="CreditCard" type="CreditCard.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code=CC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExchangeDoc" type="ExchangeDocument.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code=ET</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Cash" type="StringLength0to128">
				<xsd:annotation>
					<xsd:documentation>Presensence of this element indicates a cash transaction; FOP Code=CA</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Check" type="Check.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code=CK</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Invoice" type="Invoice.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code=IN</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GovTransRequest" type="GTR.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code=GR</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PrepaidTicketAdvice" type="PTA.Misc">
				<xsd:annotation>
					<xsd:documentation>FOP Code = PT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:choice>
	</xsd:complexType>
	<xsd:complexType name="FrequentFlyer.Misc">
		<xsd:attribute name="number" type="StringLength1to20" use="required">
			<xsd:annotation>
				<xsd:documentation>Same as customer loyalty number.  Mapped to: SR05_31_FFN</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="airlineCode" type="AirlineCode" use="required">
			<xsd:annotation>
				<xsd:documentation>Airline code of the customer loyalty number.   Mapped to: SR05_31_FAL</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="GTR.Misc">
		<xsd:sequence>
			<xsd:element name="Number" type="StringLength1to13"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="GateInformation">
		<xsd:sequence>
			<xsd:element name="Departure" type="GateStand" minOccurs="0"/>
			<xsd:element name="Arrival" type="GateStand" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="GateStand">
		<xsd:sequence>
			<xsd:element name="Gate" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="GateName.OPS">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ParkingStand" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="GateName.OPS">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Terminal" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="PassengerTerminal.OPS">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Get.MiscTransInfo">
		<xsd:sequence>
			<xsd:element name="DestCityCode" type="Location.POS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Destination city code.  Needed as a parameter to get the correct ancillary or bag fee. Mapped to: SR05_11_TCTY</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ZipCode" type="AlphaNumericStringLength1to5" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A 5-digit ZIP code that may be needed for the US tax calculation, if applicable (e.g. 76123).  Mapped to: SR05_11_ZIPC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EffectiveDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A 5-digit ZIP code that may be needed for the US tax calculation, if applicable (e.g. 76123).  Mapped to: SR05_11_ZIPC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PnrLocator" type="UpperCaseAlphaLength6" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A code associated to the reservations of the customer purchasing an ancillary service.  Mapped to: SR05_11_PNR</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NameRefNumber" type="xsd:decimal" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A name number associated to the traveller or purchaser in the PNR (e.g. 1.1)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="HotelName">
		<xsd:simpleContent>
			<xsd:extension base="StringLength1to255">
				<xsd:attribute name="ChainCode" type="StringLength0to32"/>
				<xsd:attribute name="HotelCode" type="StringLength0to32"/>
				<xsd:attribute name="CityCode" type="StringLength0to32"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Invoice.Misc">
		<xsd:sequence>
			<xsd:element name="Number" type="StringLength1to10"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Location.POS">
		<xsd:annotation>
			<xsd:documentation>A location for an airline or agency agent. Can be used to describe the actual, pseudo or home location.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="CityCode">
				<xsd:attribute name="country" type="CountryCode"/>
				<xsd:attribute name="province" type="AlphaLength2"/>
				<xsd:attribute name="number" type="AlphaNumericStringLength1to8">
					<xsd:annotation>
						<xsd:documentation>agent station number or agency iata number</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="LocationCode">
		<xsd:simpleContent>
			<xsd:extension base="StringLength1to16">
				<xsd:attribute name="name" type="StringLength1to128"/>
				<xsd:attribute name="codeContext" type="StringLength1to64"/>
				<xsd:attribute name="city" type="StringLength1to64"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Loyality">
		<xsd:annotation>
			<xsd:documentation>Unique identifier of the member in the program.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="StringLength1to32">
				<xsd:attribute name="Program" type="StringLength1to64">
					<xsd:annotation>
						<xsd:documentation>Identifier for the company owner of the loyalty program.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="Level" type="StringLength1to16">
					<xsd:annotation>
						<xsd:documentation>The level described by the loyalty program.  The value domain of level is completely under control of the airline or provider; do not make non-provider specfic assumptions about its value range.
</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="Partners" type="StringLength1to128">
					<xsd:annotation>
						<xsd:documentation>The partner(s)/vendor(s) for which the customer loyalty number is valid.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="TravelSector" type="OTA_CodeType">
					<xsd:annotation>
						<xsd:documentation>Identifies the travel sector.  Refer to IATA PADIS Code List for data element 4025.</xsd:documentation>
						<xsd:documentation>Used to identify the specific travel sector to which the loyalty program applies. Refer to OTA Codelist Travel Sector (TVS).</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="MessagingRecords">
		<xsd:sequence>
			<xsd:element name="ServiceRequestor" type="MessagingSystemRecord" minOccurs="0"/>
			<xsd:element name="RequestProxies" type="MessagingSystemRecord" minOccurs="0" maxOccurs="100"/>
			<xsd:element name="ServiceProvider" type="MessagingSystemRecord" minOccurs="0"/>
			<xsd:element name="ResponseProxies" type="MessagingSystemRecord" minOccurs="0" maxOccurs="100"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="MessagingSystemRecord">
		<xsd:annotation>
			<xsd:documentation>Text field used for intermediaries and proxies to record brief messages about the processes. Attributes record date-time and system identification information.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="Text">
				<xsd:attribute name="StartTimeStamp" type="xsd:dateTime" use="required">
					<xsd:annotation>
						<xsd:documentation>When the system stated processing the message.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="EndTimeStamp" type="xsd:dateTime" use="required">
					<xsd:annotation>
						<xsd:documentation>When the system completed processing the message. Format is a sequence of characters of the form: '-'? yyyy '-' mm '-' dd 'T' hh ':' mm ':' ss ('.' s+)? (zzzzzz)?; for example, 2002-10-10T12:00:00+05:00. </xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="SystemID" type="Identifier" use="required">
					<xsd:annotation>
						<xsd:documentation>Unique identifier for the processing system.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="SystemName" type="Identifier" use="required">
					<xsd:annotation>
						<xsd:documentation>Common name of the processing system.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="MiscTransInfo">
		<xsd:complexContent>
			<xsd:extension base="TransactionInfo">
				<xsd:attribute name="code" type="TransactionCode.Misc" use="required">
					<xsd:annotation>
						<xsd:documentation>A code that defines the type of processing to be applied from the core service - Miscellaneous Sales Receipt (MSR) or Excess Baggage (EXB).  Mapped to: SR05_11_TRT,#SR05_11_W EXB or #SR05_11_WMSR</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="OptionalService">
		<xsd:sequence>
			<xsd:element name="EmdType" type="Emd.Type" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>EMD Type. Mapped to: SR05_C5_EMT</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AirExtraItemNumber" type="xsd:integer" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Air Extra Item Number. Mapped to: SR05_C5_SNB</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OwningCarrierCode" type="AirlineCode" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Owning Carrier Code. Mapped to: SR05_C5_ALC</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IATAParameters" type="IATA.Params" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="RFIC" type="AlphaNumericStringLength1" use="optional">
			<xsd:annotation>
				<xsd:documentation>Reason for issuance code. Mapped to: SR05_C5_RFIC</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="subCode" type="StringLength1to3" use="optional">
			<xsd:annotation>
				<xsd:documentation>Reason for issuance sub-code. Mapped to: SR05_C5_RFISC</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="name" type="AlphaNumericStringLength1to30" use="optional">
			<xsd:annotation>
				<xsd:documentation>ATPCO Commercial Name. Mapped to SR05AT_C5_ACMN</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="group" type="ATPCO.Group" use="optional">
			<xsd:annotation>
				<xsd:documentation>ATPCO group. Mapped to SR05AT_C5_GRP</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="ssrCode" type="AlphaNumericStringLength4">
			<xsd:annotation>
				<xsd:documentation>Service code in the PNR associated to the item. Mapped to SR05_C5_SSR</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="bookingIndicator" type="BookingIndicator" use="optional">
			<xsd:annotation>
				<xsd:documentation>Booking indicator. Mapped to SR05_C5_BIND</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="segmentIndicator" type="SegmentIndicator" use="optional">
			<xsd:annotation>
				<xsd:documentation>Segment or Portion indicator. Mapped to SR05_C5_SIND</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="taxable" type="xsd:boolean" use="optional">
			<xsd:annotation>
				<xsd:documentation>An taxable indicator.  Mapped to: SR05_C5_IN1</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="Override.Misc">
		<xsd:sequence>
			<xsd:element name="EffectiveDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The effectivity date when override code can be used.  Mapped to:  SR05_C0_EFFD</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DiscontinueDate" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The discontinue date when the override code can be used.  Mapped to:  SR05_C0_DSCD</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="9"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="CarrierOverride" type="AlphaNumericStringLength2to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Validating carrier override for host partitions containing more than one carrier (ie LAN).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="reasonCode" type="AlphaNumericStringLength2" use="required">
			<xsd:annotation>
				<xsd:documentation>Code associated to the reason why a fee override is applied.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="reasonDesc" type="StringLength1to21" use="required">
			<xsd:annotation>
				<xsd:documentation>Text that describes the reason why a fee override is applied.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="option" type="AlphaNumericStringLength1">
			<xsd:annotation>
				<xsd:documentation>Option indicator associated to the override or reason code.  Values can be Y - remarks, T - ticket.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="POS">
		<xsd:annotation>
			<xsd:documentation>Locations:
Psuedo - Agency PCC or Agent AAA 
Actual – where the transaction is initiated
Home – assigned to the agent account</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Company" type="UpperCaseAlphaNumericLength1to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The IATA assigned code for the Agency or Airine </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Pseudo" type="PseudoCityCode.AgencyOrAgent" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Required for most sources, unless MultiHost code is provided.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MultiHost" type="AirlineCode" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Airline partition for multi-host source locations.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Actual" type="Location.POS" minOccurs="0"/>
			<xsd:element name="Home" type="Location.POS" minOccurs="0"/>
			<xsd:element name="Sine" type="StringLength1to16" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Identifies the agent or party within the requesting entity.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DutyCode" type="DutyCodeList" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An authority code assigned to a requestor.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Lniata" type="Lniata" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>LNIATA of the Console the agent signed into. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="POS.Misc">
		<xsd:sequence>
			<xsd:element name="AAA" type="Location.POS"/>
			<xsd:element name="Location" type="Location.POS" minOccurs="0"/>
			<xsd:element name="Home" type="Location.POS" minOccurs="0"/>
			<xsd:element name="Actual" type="Location.POS" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="company" type="UpperCaseAlphaNumericLength1to3" use="required"/>
		<xsd:attribute name="lniata" type="AlphaNumericStringLength6" use="required"/>
		<xsd:attribute name="sine" type="StringLength1to3"/>
		<xsd:attribute name="dutyCode" type="DutyCodeList"/>
	</xsd:complexType>
	<xsd:complexType name="PTA.Misc">
		<xsd:sequence>
			<xsd:element name="Number" type="StringLength1to14"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Parameters">
		<xsd:annotation>
			<xsd:documentation>Name value pairs of parameters where the contents are the value associated with the name. Parameters are for deployment and operational flexibility and should not be relied upon in service design. Revisions to the service should migrate parameters into the message payload or message subject and action values.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="Text">
				<xsd:attribute name="Name" type="Text"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="PassengerCounts">
		<xsd:sequence>
			<xsd:element name="Actual" type="PassengersPerClass" minOccurs="0" maxOccurs="26"/>
			<xsd:element name="Booked" type="PassengersPerClass" minOccurs="0" maxOccurs="26"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PassengersPerClass">
		<xsd:sequence>
			<xsd:element name="Count">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="PassengerCount">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Class">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="Class.OPS">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Type" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="CabinOrFareType">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PassengersPerDestination">
		<xsd:sequence>
			<xsd:element name="Destination" type="AirportCode"/>
			<xsd:element name="NumberOfPassengers" type="PassengerCount"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Passport">
		<xsd:simpleContent>
			<xsd:extension base="StringLength1to64">
				<xsd:attribute name="RPH" type="ComponentIndex"/>
				<xsd:attribute name="Country" type="CountryCode"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Payment.Misc">
		<xsd:sequence>
			<xsd:element name="Amount" type="Amount"/>
			<xsd:element name="FormOfPayment" type="FormOfPaymentChoice.Misc"/>
			<xsd:element name="FormOfIdentification" type="FormOfIdentification.Misc" minOccurs="0" maxOccurs="2"/>
			<xsd:element name="Remarks" type="Text" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonName">
		<xsd:sequence>
			<xsd:element name="Prefix" type="StringLength1to16" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Salutation of honorific. (e.g., Mr. Mrs., Ms., Miss, Dr.)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Given" type="ProperName" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Given name, first name or names</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Middle" type="ProperName" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The middle name of the person name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Surname" type="ProperName">
				<xsd:annotation>
					<xsd:documentation>Family name aslo known as last name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Suffix" type="StringLength1to16" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Hold various name suffixes and letters (e.g. Jr., Sr., III, Ret., Esq.).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Type" type="PersonNameType" minOccurs="0"/>
			<xsd:element name="PreferredFirstName" type="ProperName" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Any preferred names for first name used instead of GivenName</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PreferredSurname" type="ProperName" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Any preferred names for last  names used instead of surname</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonName.Detailed">
		<xsd:annotation>
			<xsd:documentation>Example: 
   <PersonName>
					<NamePrefix>Mr. and Mrs.</NamePrefix>
					<GivenName>Joshua</GivenName>
					<Surname>Smith</Surname>
				</PersonName>
				<PersonName NameType="0" ShareMarketInd="Inherit" ShareSynchInd="Inherit">
					<NamePrefix>Ms</NamePrefix>
					<GivenName>Delilah</GivenName>
					<MiddleName>Ann</MiddleName>
					<Surname>Beaudry</Surname>
				</PersonName>
			</xsd:documentation>
		</xsd:annotation>
		<xsd:complexContent>
			<xsd:extension base="PersonName">
				<xsd:attribute name="nameString" type="StringLength1to64">
					<xsd:annotation>
						<xsd:documentation>Unparsed name as a single string. Providers that maintain names as a single string should use this attribute to provide the most reliable form of name data. Contained name elements should be populated as best able from this name string.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="q" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation>Q is the quality indicator for the parsed name data. If true there were parsing warnings or errors detected during the parsing of the nameString into the name tokens stored in the elements of this record.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="key" type="ComponentIndex">
					<xsd:annotation>
						<xsd:documentation>Unique key provided by the source system to access this record.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="surNameKey" type="ComponentIndex">
					<xsd:annotation>
						<xsd:documentation>unique key provided by the source system for the person  described in this record used to identify and associate persons with the same surname.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="shareSync" type="ShareIndicator"/>
				<xsd:attribute name="shareMarket" type="ShareIndicator"/>
				<xsd:attribute name="source" type="StringLength1to64"/>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="PersonName.ID">
		<xsd:sequence>
			<xsd:element name="key" type="ComponentIndex" minOccurs="0"/>
			<xsd:element name="surNameKey" type="ComponentIndex" minOccurs="0"/>
			<xsd:element name="source" type="StringLength1to64" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonName.OTA">
		<xsd:annotation>
			<xsd:documentation>This provides name information for a person. OTA 1.8 = PersonNameType</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="NamePrefix" type="StringLength1to16" minOccurs="0" maxOccurs="3">
				<xsd:annotation>
					<xsd:documentation>Salutation of honorific. (e.g., Mr. Mrs., Ms., Miss, Dr.)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GivenName" type="StringLength1to64" minOccurs="0" maxOccurs="5">
				<xsd:annotation>
					<xsd:documentation>Given name, first name or names</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MiddleName" type="StringLength1to64" minOccurs="0" maxOccurs="3">
				<xsd:annotation>
					<xsd:documentation>The middle name of the person name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SurnamePrefix" type="StringLength1to16" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>e.g "van der", "von", "de"</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Surname" type="StringLength1to64">
				<xsd:annotation>
					<xsd:documentation>Family name, last name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NameSuffix" type="StringLength1to16" minOccurs="0" maxOccurs="3">
				<xsd:annotation>
					<xsd:documentation>Hold various name suffixes and letters (e.g. Jr., Sr., III, Ret., Esq.).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NameTitle" type="StringLength1to16" minOccurs="0" maxOccurs="5">
				<xsd:annotation>
					<xsd:documentation>Degree or honors (e.g., Ph.D., M.D.)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NameReference" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Used by certain agencies, and takes the format * 1-29 alphanumeric after the name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ShareSyncInd" type="ShareIndicator" default="Inherit" minOccurs="0"/>
			<xsd:element name="ShareMarketInd" type="ShareIndicator" default="Inherit" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="NameType" type="StringLength1to64">
			<xsd:annotation>
				<xsd:documentation>Type of name of the individual, such as former, nickname, alternate or alias name. Refer to OTA Code List Name Type (NAM).
Name Type		(NAM)	
	1	Former
	2	Nickname
	3	Alternate
	4	Maiden
</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="travelerRefNumber" type="ComponentIndex"/>
	</xsd:complexType>
	<xsd:complexType name="PersonName.Query">
		<xsd:sequence>
			<xsd:element name="SurnamePrefix" type="StringLength1to16" minOccurs="0"/>
			<xsd:element name="Surname" type="ProperName" minOccurs="0"/>
			<xsd:element name="nameString" type="StringLength1to64" minOccurs="0"/>
			<xsd:element name="source" type="StringLength1to64" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonName.Simple">
		<xsd:annotation>
			<xsd:documentation>Example: 
   &lt;PersonName&gt;
      &lt;GivenName&gt;Joshua&lt;/GivenName&gt;
	&lt;MiddelName&gt;Henry&lt;/Middlename&gt;
      &lt;Surname&gt;Smith&lt;/Surname&gt;
   &lt;/PersonName&gt;</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="GivenName" type="ProperName" minOccurs="0" maxOccurs="5"/>
			<xsd:element name="MiddleName" type="ProperName" minOccurs="0" maxOccurs="3"/>
			<xsd:element name="Surname" type="ProperName"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Relationship">
		<xsd:simpleContent>
			<xsd:extension base="StringLength0to128">
				<xsd:attribute name="Type" type="Relationships.Personal"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Remark">
		<xsd:simpleContent>
			<xsd:extension base="StringLength1to128">
				<xsd:attribute name="Type" type="OTA_CodeType">
					<xsd:annotation>
						<xsd:documentation>Type of special remark used (e.g., itinerary remark, invoice remark). Refer to OTA Code List Special Remark Option Type (SRO).
Possible Sabre Web Services values for "Remark@RemarkType" are: BasicRemark, AlphaCodedRemark, ClientAddressRemark, DeliveryAddressRemark, InvoiceRemark, ItineraryRemark, GroupNameRemark, HistoricalRemark, HiddenRemark, or CorporateNumberRemark
OTA Values 1 through 31 meaning: Itinerary, Invoice, Endorsement, Split, Save, Confidential, Free, Group revenue management system (GRMS), General, Address, Document instructions, electronic courier device code, Boarding pass, Pocket itinerary, Destination purpose, Client account, Corporate id, Commission, Electronic certificate, Tour, Passenger email, Travel agency email, Passenger message, Client billing address, Client delivery address, Consolidator, Unique, Group type, Customer type, Travel flexibility, Show up</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="Code" type="StringLength1to64"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Remarks">
		<xsd:sequence>
			<xsd:element name="Remark" maxOccurs="100">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="Remark">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ResultRecord">
		<xsd:sequence>
			<xsd:element name="ErrorSource" type="SystemNameAndId" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>endpoint address (url) or system name of the system that could not be reached. For application errors, the attribute may be omitted or identify a system the application is dependent upon that failed to respond.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Status" type="ErrorOrSuccessCode"/>
			<xsd:element name="CompletionStatus" type="CompletionCodes" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An indicator to reflect the severity of this condition reported in the result record.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="System" type="SystemNameAndId" minOccurs="0"/>
			<xsd:element name="SystemSpecificResults" type="SystemSpecificResults" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
		<xsd:attribute name="conversationID" type="Identifier">
			<xsd:annotation>
				<xsd:documentation>The ConversationId element is a string identifying the set of related messages that make up a conversation between two Parties. The Party initiating a conversation determines the value of the ConversationId element that shall be reflected in all messages pertaining to that conversation. It remains constant for all messages within a conversation.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="messageId" type="Identifier">
			<xsd:annotation>
				<xsd:documentation>id is a unique identifier for this error message</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="version" type="Identifier">
			<xsd:annotation>
				<xsd:documentation>version should match the version of the namespace and schema.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="timeStamp" type="xsd:dateTime">
			<xsd:annotation>
				<xsd:documentation>Date and time when the result record was created.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="Seat.ACS">
		<xsd:sequence>
			<xsd:element name="SeatRow" type="NumericLength1to2"/>
			<xsd:element name="SeatColumn" type="UpperCaseStringLength1"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="SSR">
		<xsd:simpleContent>
			<xsd:extension base="StringLength0to255">
				<xsd:attribute name="Code" type="StringLength1to16"/>
				<xsd:attribute name="Type" type="StringLength1to16"/>
				<xsd:attribute name="Airline" type="AirlineCode.2to4Char">
					<xsd:annotation>
						<xsd:documentation>The airline that the SSR was sent to.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="STL_Header.RQ">
		<xsd:annotation>
			<xsd:documentation>Sabre Standard Payload Header. Information in the header is intended to separate transport and processing information from actual message data. Header information may be replicated in the messaging system header (SOAP or JMS header). This data is inteded for use with content-based routing and other tasks asscociated with integration.  NOTE: messaging and transport systems may and should add content to the header whereas they should never change the actual message subject contents.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Action" type="Text.Short" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Details, qualifiers and parameters to the message action verb. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Subject" type="Text.Short" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Details, qualifiers and parameters to the message subject noun. Typically will be used to request level of detail desired in the response or parameters not caputred by the query form of the noun.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Messaging" type="MessagingRecords" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Messaging section provides an area for each system interacting with the message to record a brief message about thier interactions. Service proxies and utility services such as transformation and validation should use this area to record when they processed the message and the resulting status.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Parameters" type="Parameters" minOccurs="0" maxOccurs="100">
				<xsd:annotation>
					<xsd:documentation>Generalized name-value pairs. These parameters are intended for integration specific use only duriing development and testing. These parameters must not be relied upon for production operation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Security" type="Text.Long" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="conversationID" type="Identifier">
			<xsd:annotation>
				<xsd:documentation>The ConversationId element is a string identifying the set of related messages that make up a conversation between two Parties. The Party initiating a conversation determines the value of the ConversationId element that shall be reflected in all messages pertaining to that conversation. It remains constant for all messages within a conversation.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="messageID" type="Identifier">
			<xsd:annotation>
				<xsd:documentation>The MessageId element is a globally unique identifier for each message [see RFC2822]. It is an unique message identifier that refers to a particular version of a particular message.  The uniqueness of the message identifier should be guaranteed by the host that generates it.  This message identifier is intended to be machine readable and not necessarily meaningful to humans.  A message identifier pertains to exactly one instantiation of a particular message; subsequent revisions to the message each receive new message identifiers.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="version" type="Identifier"/>
		<xsd:attribute name="timeStamp" type="xsd:dateTime">
			<xsd:annotation>
				<xsd:documentation>Date and time when the result record was created.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="diagnosticLevel" type="DiagnosticLevels"/>
		<xsd:attribute name="diagnosticData" type="Text.Long"/>
	</xsd:complexType>
	<xsd:complexType name="STL_Header.RS">
		<xsd:annotation>
			<xsd:documentation>Sabre Standard Payload Header. Information in the header is intended to separate transport and processing information from actual message data. Header information may be replicated in the messaging system header (SOAP or JMS header). This data is inteded for use with content-based routing and other tasks asscociated with integration.  NOTE: messaging and transport systems may and should add content to the header whereas they should never change the actual message subject contents.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Results" type="ResultRecord">
				<xsd:annotation>
					<xsd:documentation>Response message header Results are used to exchange information about the nature of a failure or success. This record must be provided in successful service invocations. May also contain system specific error, result and diagnostic data.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Messaging" type="MessagingRecords" minOccurs="0"/>
			<xsd:element name="Security" type="Text.Long" minOccurs="0"/>
			<xsd:element name="Parameters" type="Parameters" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Generalized name-value pairs. These parameters are intended for integration specific use only duriing development and testing. These parameters must not be relied upon for production operation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="State">
		<xsd:simpleContent>
			<xsd:extension base="ProperName">
				<xsd:attribute name="StateProvCode" type="StateProvCode"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Street">
		<xsd:simpleContent>
			<xsd:extension base="ProperName">
				<xsd:attribute name="StreetNmbrSuffix" type="StringLength1to8">
					<xsd:annotation>
						<xsd:documentation>Usually a letter right after the street number (A in 66-A, B in 123-B etc).</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="StreetDirection" type="StringLength1to8">
					<xsd:annotation>
						<xsd:documentation>Street direction of an address (e.g., N, E, S, NW, SW).</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="RuralRouteNmbr" type="NumericStringLength1to5">
					<xsd:annotation>
						<xsd:documentation>Numerical equivalent of a rural township as defined within a given area (e.g., 12, 99).</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="PO_Box" type="StringLength1to16">
					<xsd:annotation>
						<xsd:documentation>Defines a Post Office Box number.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="SystemNameAndId">
		<xsd:annotation>
			<xsd:documentation>System name plus an Id attribute used to uniquily identify the specific system.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="Identifier">
				<xsd:attribute name="id" type="Identifier"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="SystemSpecificResults">
		<xsd:sequence>
			<xsd:element name="ErrorMessage" type="ErrorMessage" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Application specific Error code and Message. A textual description to provide more information about the specific error.
TODO - make into simple content type with code as numeric attribute
TODO - shorten names on TimeStamps</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ShortText" type="Text.Short" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An abbreviated version of the error in textual format.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Element" type="Text.Long" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>If present, this attribute may identify an unknown or misspelled tag that caused an error in processing. It is recommended that the Tag attribute use XPath notation to identify the location of a tag in the event that more than one tag of the same name is present in the document. Alternatively, the tag name alone can be used to identify missing data [Type=ReqFieldMissing].</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RecordID" type="Identifier" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>If present, this attribute allows for batch processing and the identification of the record that failed amongst a group of records. This value may contain a concatenation of a unique failed transaction ID with specific record(s) associated with that transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DocURL" type="xsd:anyURI" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>If present, this attribute refers to an online description of the error that occurred.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DiagnosticResults" type="DiagnosticResults" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>For data not defined elsewhere in the results record. Structure of the contents must be defined elsewhere in the target schema namespace.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="serviceName" type="xsd:string">
			<xsd:annotation>
				<xsd:documentation>Service name like SSCI TPF, PNR, TKT or Pricing</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="Tax.Misc">
		<xsd:sequence>
			<xsd:element name="Amount" type="Amount"/>
		</xsd:sequence>
		<xsd:attribute name="exempt" type="xsd:boolean" default="false">
			<xsd:annotation>
				<xsd:documentation>An indicator that a tax has been exempted.  Mapped to:</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="code" type="AlphaNumericStringLength2to3" use="required">
			<xsd:annotation>
				<xsd:documentation>A code that applies to the tax (e.g, US, ZP).  Mapped to:  SR05_C2_TCOD</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="Telephone">
		<xsd:simpleContent>
			<xsd:extension base="PhoneNumber">
				<xsd:attribute name="location">
					<xsd:annotation>
						<xsd:documentation>List will be based on PPP Codes
						Refer to OTA Code List Phone Location Type (PLT).
	1	Brand reservations office
	2	Central reservations office
	3	Property reservation Office
	4	Property direct
	5	Sales office
	6	Home
	7	Office
	8	Other
	9	Managing company</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="use" type="StringLength1to5">
					<xsd:annotation>
						<xsd:documentation>List will be based on PPP Codes

						Describes the type of telephone number, in the context of its general use (e.g. Home, Business, Emergency Contact, Travel Arranger, Day, Evening). Refer to OTA Code List Phone Use Type (PUT).
1	Emergency contact
2	Travel arranger
3	Daytime contact
4	Evening contact
5	Contact
6	Toll free number
7	Guest use
8	Pickup contact</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="countryCode">
					<xsd:annotation>
						<xsd:documentation>Code assigned by telecommunications authorities for international country access identifier.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="extension">
					<xsd:annotation>
						<xsd:documentation>Extension to reach a specific party at the phone number.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="remark">
					<xsd:annotation>
						<xsd:documentation>A remark associated with the telephone number.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="Telephone.OTA">
		<xsd:simpleContent>
			<xsd:extension base="PhoneNumber">
				<xsd:attribute name="location" type="OTA_CodeType">
					<xsd:annotation>
						<xsd:documentation>Refer to OTA Code List Phone Location Type (PLT).
	1	Brand reservations office
	2	Central reservations office
	3	Property reservation Office
	4	Property direct
	5	Sales office
	6	Home
	7	Office
	8	Other
	9	Managing company
</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="use" type="OTA_CodeType">
					<xsd:annotation>
						<xsd:documentation>Describes the type of telephone number, in the context of its general use (e.g. Home, Business, Emergency Contact, Travel Arranger, Day, Evening). Refer to OTA Code List Phone Use Type (PUT).
1	Emergency contact
2	Travel arranger
3	Daytime contact
4	Evening contact
5	Contact
6	Toll free number
7	Guest use
8	Pickup contact
</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="countryCode" type="NumericStringLength1to3">
					<xsd:annotation>
						<xsd:documentation>Code assigned by telecommunications authorities for international country access identifier.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="areaCode" type="NumericStringLength1to8">
					<xsd:annotation>
						<xsd:documentation>Code assigned for telephones in a specific region, city, or area.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="extension" type="StringLength1to5">
