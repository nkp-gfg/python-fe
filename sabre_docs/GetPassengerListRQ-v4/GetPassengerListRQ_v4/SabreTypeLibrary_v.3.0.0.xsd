				<xsd:annotation>
					<xsd:documentation>not valid without flight coupon text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TicketText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>ticket type text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VCRNumber" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="couponNumber" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>VCR coupon number</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="validatingCarrier" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>validating carrier of vitual coupon record</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="checkDigit" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>vitual coupon record check digit</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="DocumentType" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>document type</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SSRCode" type="xsd:string" minOccurs="0" maxOccurs="4">
				<xsd:annotation>
					<xsd:documentation>ssr code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PingTip" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>ping tip</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpeedText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>speed text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EvenMoreSpeedText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>even more speed text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BoardingPassOnlyText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>boarding pass only text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PlusInfantText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>plus infant text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ChildText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>child text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="THRUText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>thru text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PremiumText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>premium text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExitText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Exit text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TBOText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>TBO text</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TBOCityCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>TBO city code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CabinText" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>cabin name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExclusiveWaitingArea" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Exclusive waiting area</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LoungeAccess" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>lounge access</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpanishResident" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Spanish Resident</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpanishLargeFamily" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Spanish Large Family</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AncillaryList" type="AncillaryList.ACS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Ancillary list</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="AncillaryList.ACS">
		<xsd:sequence>
			<xsd:element name="Ancillary" type="Ancillary.ACS" minOccurs="0" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Ancillary.ACS">
		<xsd:sequence>
			<xsd:element name="AncillaryDescriptions" type="AncillaryDescriptions.ACS">
				<xsd:annotation>
					<xsd:documentation>Ancillary descriptions list</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="groupCode" type="xsd:string">
			<xsd:annotation>
				<xsd:documentation>Ancillary Group Code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="subGroupCode" type="xsd:string">
			<xsd:annotation>
				<xsd:documentation>Ancillary Sub Group Code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="AncillaryDescriptions.ACS">
		<xsd:sequence>
			<xsd:element name="Description" maxOccurs="3">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="id" type="xsd:string">
								<xsd:annotation>
									<xsd:documentation>Ancillary description id, 1, 2, 3</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PNRLocator">
		<xsd:simpleContent>
			<xsd:extension base="UpperCaseAlphaLength6">
				<xsd:attribute name="nameReferenceNumber" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>PNR name reference number ex 1.1, 1.2 etc</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="nameAssociationId" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>PNR name association ID ex 01, 02 etc</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="SeatDetails.ACS">
		<xsd:annotation>
			<xsd:documentation>Seat details.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SeatNumber" type="xsd:string" maxOccurs="1"/>
			<xsd:element name="SeatAllowedIndicator" type="xsd:boolean"/>
			<xsd:element name="SeatChargeableIndicator" type="xsd:boolean"/>
			<xsd:element name="EntitlementRuleId" type="xsd:string" minOccurs="0"/>
			<xsd:element name="FeeWaiverRuleId" type="xsd:string" minOccurs="0"/>
			<xsd:element name="AEItemID" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>unique id of the AE Associated to this Seat</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Error.ACS">
		<xsd:annotation>
			<xsd:documentation>Error message.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Code" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Error code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Message" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Error message</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Severity" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Severity for example CRITICAL</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ErrorSource" type="SystemNameAndId" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>endpoint address (url) or system name of the system that could not be reached. For application errors, the attribute may be omitted or identify a system the application is dependent upon that failed to respond.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Warning.ACS">
		<xsd:annotation>
			<xsd:documentation>Warning message.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Code" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Warning code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Message" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Warning message</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Severity" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Severity for example CRITICAL</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WarningSource" type="SystemNameAndId" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>endpoint address (url) or system name of the system that could not be reached. For application errors, the attribute may be omitted or identify a system the application is dependent upon that failed to respond.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ClientContext.ACS">
		<xsd:attribute name="name" type="xsd:string" use="required"/>
	</xsd:complexType>
	<xsd:complexType name="PassengerEditsType">
		<xsd:annotation>
			<xsd:documentation>Passenger Edit code complex Type</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Edit" type="EditType" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>Edit code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="EditType">
		<xsd:annotation>
			<xsd:documentation>Edit Type Complex type</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="EditCodeAttributeList" type="EditCodeAttributesType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Edit code attribute list</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="name" type="xsd:string">
			<xsd:annotation>
				<xsd:documentation>Edit code name</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="infant" type="xsd:boolean">
			<xsd:annotation>
				<xsd:documentation>populate this attribute if the data is of an infant</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="EditCodeAttributesType">
		<xsd:annotation>
			<xsd:documentation>Edit code attributes complec type</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="EditCodeAttribute" type="EditCodeAttributeType" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>Edit code Attribute</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="EditCodeAttributeType">
		<xsd:annotation>
			<xsd:documentation>Edit code Attribute Complex type</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Values" type="ValuesType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Values for the passenger edit</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="name" type="xsd:string">
			<xsd:annotation>
				<xsd:documentation>attribute name for the edit code</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="ValuesType">
		<xsd:annotation>
			<xsd:documentation>Edit code Values complex type</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Value" type="xsd:string" minOccurs="0" maxOccurs="99">
				<xsd:annotation>
					<xsd:documentation>Value for Passenger Eidt code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Address.Plain">
		<xsd:annotation>
			<xsd:documentation>Address Type Limited to 35chars max </xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="StreetAddress" type="UpperCaseStringLength1to35" minOccurs="0"/>
			<xsd:element name="City" type="UpperCaseStringLength1to35" minOccurs="0"/>
			<xsd:element name="StateProvince" type="UpperCaseStringLength1to35" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>state or province</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CountryCode" type="UpperCaseAlphaLength2to3" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>country of address, 2 or 3-letter country code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ZipCode" type="UpperCaseStringLength1to20" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonName.Plain">
		<xsd:annotation>
			<xsd:documentation>Person Name Type </xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="LastName" type="UpperCaseStringLength1to30" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger's last name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FirstName" type="UpperCaseStringLength1to30" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passenger's first name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MiddleName" type="UpperCaseStringLength1to30" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>passengers middle Name</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
</xsd:schema>
