			<xsd:element name="CountryName" type="CountryCode" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Address.Detailed">
		<xsd:annotation>
			<xsd:documentation>Sabre - use only when detailed and structured address is required.
Create customized extensions and add to choice group when host applications have different detailed structure to capture.
OTA 1.8: AddressType = Provides address information. 
</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Building" type="Building" minOccurs="0" maxOccurs="2">
				<xsd:annotation>
					<xsd:documentation>Building name, room, apartment, or suite number.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Street" type="Street" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>May contain the street number and street name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="City" type="StringLength1to64" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>City (e.g., Dublin), town, or postal station (i.e., a postal service territory, often used in a military address).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="County" type="StringLength1to32" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>County or Region Name (e.g., Fairfax).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StateProv" type="StringLength1to64" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>State or Province name (e.g., Texas).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Country" type="StringLength1to64" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Country name (e.g., Ireland).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PostalCode" type="StringLength1to16" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Post Office Code number.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Address.Lines">
		<xsd:sequence>
			<xsd:element name="AddressLine" type="StringLength1to255" minOccurs="0" maxOccurs="99"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="Address.Simple">
		<xsd:annotation>
			<xsd:documentation>Use for most addresses. Contents are semi-formatted, with simple city, state, country and postal code broken out.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Line" type="StringLength1to255" minOccurs="0" maxOccurs="6">
