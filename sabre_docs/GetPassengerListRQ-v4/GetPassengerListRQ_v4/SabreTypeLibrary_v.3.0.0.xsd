				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AircraftOwner" minOccurs="0">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="AirlineCode">
							<xsd:attribute name="IsChanged" type="xsd:boolean"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AircraftType" minOccurs="0">
