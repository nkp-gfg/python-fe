	<xsd:complexType name="AirportTax">
		<xsd:annotation>
			<xsd:documentation>Domestic airport taxes collected from and paid by the customer</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Amount" type="Amount" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="taxCode">
			<xsd:annotation>
				<xsd:documentation>A code that applies to the tax (e.g, US, ZP)</xsd:documentation>
			</xsd:annotation>
			<xsd:simpleType>
				<xsd:restriction base="AlphaNumericStringLength2to3">
					<xsd:enumeration value="XF"/>
					<xsd:enumeration value="ZP"/>
				</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="airportCode" type="CityCode" use="required">
			<xsd:annotation>
				<xsd:documentation>A city code associated to ZP and XF taxes</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
	</xsd:complexType>
	<xsd:complexType name="Amount">
		<xsd:simpleContent>
			<xsd:extension base="_amount">
				<xsd:attribute name="currencyCode" type="xsd:string" default="USD"/>
